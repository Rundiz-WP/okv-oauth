{
    "moduleName": "Rundiz OAuth",
    "wpDev": true,
    "build": {
        "clean": {
            "destinations": [
            ]
        },
        "copy": {
            "copyTasks": [
            ],
            "copyWP": [
                {
                    "patterns": "App/**",
                    "destination": "App"
                },
                {
                    "patterns": "assets/**",
                    "destination": "assets"
                },
                {
                    "patterns": "blocks/**",
                    "destination": "blocks"
                },
                {
                    "patterns": "languages/**",
                    "destination": "languages"
                },
                {
                    "patterns": "templates/**",
                    "destination": "templates"
                },
                {
                    "patterns": "*.md",
                    "destination": "."
                },
                {
                    "patterns": "*.php",
                    "destination": "."
                },
                {
                    "patterns": "*.txt",
                    "destination": "."
                }
            ]
        }
    },
    "watch": {
        "watcher": [
            {
                "patterns": "App/**",
                "destination": "App"
            },
            {
                "patterns": "assets/**",
                "destination": "assets"
            },
            {
                "patterns": "blocks/**",
                "destination": "blocks"
            },
            {
                "patterns": "languages/**",
                "destination": "languages"
            },
            {
                "patterns": "templates/**",
                "destination": "templates"
            },
            {
                "patterns": "*.php",
                "destination": "."
            }
        ]
    },
    "pack": {
        "versionHeaderFile": "readme.txt",
        "versionPattern": "Stable tag(\\s?)(:?)(\\s?)(?<version>([\\d\\.]+)([-+\\.0-9a-z]*))",
        "packPatterns": {
            "dev": {
                "patterns": [
                    "**",
                    ".*/**",
                    ".*"
                ],
                "options": {
                    "ignore": [
                        ".backup",
                        ".dist",
                        ".git",
                        ".phpdoc",
                        ".phpunit*",
                        ".phpunit.cache",
                        "composer.lock",
                        "node_modules",
                        "package-*.json"
                    ]
                }
            },
            "prod": {
                "patterns": [
                    "**"
                ],
                "options": {
                    "ignore": [
                        ".*",
                        ".backup",
                        ".dev-notes",
                        ".dist",
                        ".git",
                        ".phpdoc",
                        ".phpunit*",
                        ".phpunit.cache",
                        "assets-src",
                        "blocks-src",
                        "composer.lock",
                        "node_modules",
                        "node_tasks",
                        "package*.json",
                        "phpunit.xml*",
                        "tests"
                    ]
                }
            }
        },
        "zipFilePrefix": "$folderName$",
        "zipOptions": {
            "zipPrefix": "$folderName$"
        }
    }
}